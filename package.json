{
  "name": "my-angular",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch",
    "prepare": "husky",
    "postinstall": "bun run lint:write",
    "eslint:check": "eslint .",
    "eslint:write": "eslint . --fix",
    "prettier:check": "prettier -c .",
    "prettier:write": "prettier -lw .",
    "lint:check": "bun run eslint:check && bun run prettier:check",
    "lint:write": "bun run eslint:write && bun run prettier:write"
  },
  "dependencies": {
    "@angular/animations": "^19.0.5",
    "@angular/cdk": "^19.0.4",
    "@angular/common": "^19.0.5",
    "@angular/compiler": "^19.0.5",
    "@angular/core": "^19.0.5",
    "@angular/forms": "^19.0.5",
    "@angular/platform-browser": "^19.0.5",
    "@angular/platform-browser-dynamic": "^19.0.5",
    "@angular/router": "^19.0.5"
  },
  "devDependencies": {
    "@angular/build": "^19.0.6",
    "@angular/cli": "^19.0.6",
    "@angular/compiler-cli": "^19.0.5",
    "@eslint/js": "^9.17.0",
    "angular-eslint": "^19.0.2",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0-beta.8",
    "typescript": ">=5.5.0 <5.7.0",
    "typescript-eslint": "^8.18.2"
  }
}
