{
  "name": "my-angular",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "ng serve --no-hmr",
    "build": "ng build",
    "watch": "ng build --watch",
    "prepare": "husky",
    "postinstall": "bun run lint:write",
    "eslint:check": "eslint .",
    "eslint:write": "eslint . --fix",
    "prettier:check": "prettier -c .",
    "prettier:write": "prettier -lw .",
    "lint:check": "bun run eslint:check & bun run prettier:check",
    "lint:write": "bun run eslint:write && bun run prettier:write"
  },
  "dependencies": {
    "@angular/animations": "19.2.1",
    "@angular/cdk": "19.2.2",
    "@angular/common": "19.2.1",
    "@angular/compiler": "19.2.1",
    "@angular/core": "19.2.1",
    "@angular/forms": "19.2.1",
    "@angular/platform-browser": "19.2.1",
    "@angular/platform-browser-dynamic": "19.2.1",
    "@angular/router": "19.2.1",
    "@ngrx/store": "19.0.1"
  },
  "devDependencies": {
    "@angular/build": "19.2.1",
    "@angular/cli": "19.2.1",
    "@angular/compiler-cli": "19.2.1",
    "@eslint/js": "9.22.0",
    "angular-eslint": "19.2.1",
    "eslint": "9.22.0",
    "husky": "9.1.7",
    "prettier": "3.5.3",
    "tailwindcss": "4.0.13",
    "typescript": "^5.8.2",
    "typescript-eslint": "8.26.1"
  }
}
