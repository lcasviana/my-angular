{
  "name": "my-angular",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "ng serve --no-hmr",
    "build": "ng build",
    "watch": "ng build --watch",
    "prepare": "husky",
    "postinstall": "bun run lint:write",
    "eslint:check": "eslint .",
    "eslint:write": "eslint . --fix",
    "prettier:check": "prettier -c --log-level=warn .",
    "prettier:write": "prettier -lw --log-level=warn .",
    "lint:check": "bun run eslint:check & bun run prettier:check",
    "lint:write": "bun run eslint:write && bun run prettier:write"
  },
  "dependencies": {
    "@angular/animations": "20.0.5",
    "@angular/cdk": "20.0.4",
    "@angular/common": "20.0.5",
    "@angular/compiler": "20.0.5",
    "@angular/core": "20.0.5",
    "@angular/forms": "20.0.5",
    "@angular/platform-browser": "20.0.5",
    "@angular/platform-browser-dynamic": "20.0.5",
    "@angular/router": "20.0.5",
    "@ngrx/operators": "19.2.1",
    "@ngrx/signals": "19.2.1",
    "@primeng/themes": "19.1.3",
    "primeicons": "7.0.0",
    "primeng": "19.1.3",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular/build": "20.0.4",
    "@angular/cli": "20.0.4",
    "@angular/compiler-cli": "20.0.5",
    "@eslint/js": "9.30.0",
    "@tailwindcss/postcss": "4.1.11",
    "@types/node": "24.0.8",
    "angular-eslint": "20.1.1",
    "eslint": "9.30.0",
    "husky": "9.1.7",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "tailwindcss": "4.1.11",
    "typescript": "5.8.3",
    "typescript-eslint": "8.35.1"
  }
}
