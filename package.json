{
  "name": "my-angular",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "ng build my-design-system --watch & ng serve",
    "build": "ng build my-design-system & ng build my-angular",
    "lint": "ng lint && npx stylelint '**/*.scss'",
    "postinstall": "husky install",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable",
    "docs:json": "compodoc -p ./tsconfig.json -e json -d .",
    "storybook": "yarn docs:json && start-storybook -p 6006",
    "storybook:build": "yarn docs:json && build-storybook"
  },
  "dependencies": {
    "@angular/animations": "^15.2.7",
    "@angular/common": "^15.2.7",
    "@angular/compiler": "^15.2.7",
    "@angular/core": "^15.2.7",
    "@angular/forms": "^15.2.7",
    "@angular/platform-browser": "^15.2.7",
    "@angular/platform-browser-dynamic": "^15.2.7",
    "@angular/router": "^15.2.7",
    "rxjs": "^7.8.0",
    "tslib": "^2.5.0",
    "zone.js": "^0.13.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^15.2.6",
    "@angular-eslint/builder": "^15.2.1",
    "@angular-eslint/eslint-plugin": "^15.2.1",
    "@angular-eslint/eslint-plugin-template": "^15.2.1",
    "@angular-eslint/schematics": "^15.2.1",
    "@angular-eslint/template-parser": "^15.2.1",
    "@angular/cli": "^15.2.6",
    "@angular/compiler-cli": "^15.2.7",
    "@babel/core": "^7.21.4",
    "@compodoc/compodoc": "^1.1.19",
    "@storybook/addon-actions": "^7.0.5",
    "@storybook/addon-essentials": "^7.0.5",
    "@storybook/addon-interactions": "^7.0.5",
    "@storybook/addon-links": "^7.0.5",
    "@storybook/angular": "^7.0.5",
    "@storybook/builder-webpack5": "^7.0.5",
    "@storybook/manager-webpack5": "^6.5.16",
    "@storybook/testing-library": "^0.1.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "autoprefixer": "^10.4.14",
    "babel-loader": "^9.1.2",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-storybook": "^0.6.11",
    "husky": "^8.0.3",
    "ng-packagr": "^15.2.2",
    "postcss": "^8.4.22",
    "prettier": "^2.8.7",
    "stylelint": "^15.5.0",
    "stylelint-config-standard-scss": "^8.0.0",
    "tailwindcss": "^3.3.1",
    "typescript": "^4.9.5"
  }
}
